---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import BaseHead from '@/components/layout/BaseHead.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import type { Locale } from '@/consts';
import { t } from '@/i18n/ui';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  ogImage?: string;
  noindex?: boolean;
  person?: boolean;
  transitions?: boolean;
}

const {
  title,
  description,
  locale = 'en',
  ogImage,
  noindex,
  person = false,
  transitions = true,
} = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead {title} {description} {locale} {ogImage} {noindex} {person} />
    {transitions && <ClientRouter />}
  </head>
  <body>
    <a href="#main" class="skip-link">{t('skip.link', locale)}</a>
    <Header {locale} />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
