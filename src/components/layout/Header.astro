---
import { NAV, SITE, type Locale } from '@/consts';
import { t, localizePath } from '@/i18n/ui';
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  locale?: Locale;
  currentPath?: string;
}

const { locale = SITE.defaultLocale, currentPath = Astro.url.pathname } = Astro.props;

const localePrefix = `/${locale}`;
const pathInLocale = currentPath.startsWith(localePrefix + '/') || currentPath === localePrefix
  ? currentPath.slice(localePrefix.length) || '/'
  : currentPath;
---

<header class="header">
  <a href={`/${locale}/`} class="header__brand" aria-label={SITE.name}>
    <span class="header__prompt" aria-hidden="true">&gt; </span>damienthumerel.com
  </a>

  <nav class="header__nav" aria-label="primary">
    <ul class="header__nav-list">
      {NAV.map((item) => {
        const isActive = pathInLocale === item.href || pathInLocale.startsWith(item.href + '/');
        return (
          <li>
            <a
              href={localizePath(item.href, locale)}
              class:list={['header__link', { 'header__link--active': isActive }]}
              aria-current={isActive ? 'page' : undefined}
            >{t(item.tKey, locale)}</a>
          </li>
        );
      })}
    </ul>
  </nav>

  <div class="header__lang">
    <LangSwitcher {locale} {currentPath} />
  </div>
</header>

<style>
  .header {
    width: 100%;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-3) var(--content-pad) var(--space-2);
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "brand   lang"
      "nav     nav";
    align-items: baseline;
    gap: var(--space-2);
  }

  @media (min-width: 768px) {
    .header {
      grid-template-columns: auto 1fr auto;
      grid-template-areas: "brand nav lang";
    }
  }

  .header__brand {
    grid-area: brand;
    color: var(--accent);
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    white-space: nowrap;
  }
  .header__brand:hover { filter: brightness(1.2); }
  .header__prompt { color: var(--accent); }

  .header__nav {
    grid-area: nav;
    overflow-x: auto;
  }
  .header__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0 var(--space-2);
  }
  .header__link {
    color: var(--fg-dim);
    text-decoration: none;
  }
  .header__link::before {
    content: '· ';
    color: var(--border);
    margin-right: 0.25ch;
  }
  .header__nav-list > li:first-child .header__link::before {
    content: '';
    margin: 0;
  }
  .header__link:hover { color: var(--accent); }
  .header__link--active {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .header__lang {
    grid-area: lang;
    color: var(--fg-dim);
  }
</style>
