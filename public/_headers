/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()
  Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' static.cloudflareinsights.com; img-src 'self' data:; font-src 'self'; connect-src 'self' cloudflareinsights.com; base-uri 'self'; form-action 'self'; frame-ancestors 'none';

# Long-cache static font files (immutable filenames are fine for woff2 subsets).
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
